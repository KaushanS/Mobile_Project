<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F1EB"
    android:fillViewport="true"
    tools:context=".profile.EditProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header with Back Button and Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:textColor="#0E1A2B"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </LinearLayout>

        <!-- Profile Photo Section -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp">

            <!-- Profile Circle -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/rounded_frame_bg"
                android:backgroundTint="#7FB5A5">

                <TextView
                    android:id="@+id/tvInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="K"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Camera Icon -->
            <FrameLayout
                android:id="@+id/btnChangePhoto"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/rounded_frame_bg"
                android:backgroundTint="#2F8A6E">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📷"
                    android:textSize="18sp" />
            </FrameLayout>
        </FrameLayout>

        <!-- Tap to change photo text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Tap to change photo"
            android:textColor="#7B7B7B"
            android:textSize="14sp" />

        <!-- Full Name Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="FULL NAME"
            android:textAllCaps="true"
            android:textColor="#909090"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#DADADA"
            app:boxStrokeWidth="1dp"
            app:startIconTint="#6E4B95">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kasun Perera"
                android:inputType="textPersonName"
                android:paddingVertical="14dp"
                android:textColor="#25313F"
                android:textColorHint="#8C8C8C"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email Address Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="EMAIL ADDRESS"
            android:textAllCaps="true"
            android:textColor="#909090"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#DADADA"
            app:boxStrokeWidth="1dp"
            app:startIconTint="#C8A7D8">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="kasun@email.com"
                    android:enabled="false"
                    android:inputType="textEmailAddress"
                    android:paddingVertical="14dp"
                    android:textColor="#25313F"
                    android:textColorHint="#8C8C8C"
                    android:textSize="18sp" />

            </LinearLayout>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Info Message -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_frame_bg"
            android:backgroundTint="#D4F1E8"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="start">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Email address cannot be changed here. Contact support if needed."
                android:textColor="#2F8A6E"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- Phone Number Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="PHONE NUMBER (OPTIONAL)"
            android:textAllCaps="true"
            android:textColor="#909090"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#DADADA"
            app:boxStrokeWidth="1dp"
            app:startIconTint="#5BA3D0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+94 7X XXX XXXX"
                android:inputType="phone"
                android:paddingVertical="14dp"
                android:textColor="#25313F"
                android:textColorHint="#8C8C8C"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Profile Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text=" Save Profile"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:backgroundTint="#157A53"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
