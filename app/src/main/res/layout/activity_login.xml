<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F1EB"
    android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome\nBack 🔐"
            android:textColor="#0E1A2B"
            android:textSize="44sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-2dp" />

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Sign in to your account"
            android:textColor="#7B7B7B"
            android:textSize="18sp" />

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="EMAIL"
            android:textAllCaps="true"
            android:textColor="#909090"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#DADADA"
            app:boxStrokeWidth="1dp"
            app:startIconTint="#C8A7D8">

            <com.google.android.material.textfield.TextInputEditText android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="kasun@mail.com"
                android:inputType="textEmailAddress"
                android:paddingVertical="14dp"
                android:textColor="#25313F"
                android:textColorHint="#8C8C8C"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="PASSWORD"
            android:textAllCaps="true"
            android:textColor="#909090"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#DADADA"
            app:boxStrokeWidth="1dp"
            app:endIconMode="password_toggle"
            app:startIconTint="#F2B04A">

            <com.google.android.material.textfield.TextInputEditText android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:paddingVertical="14dp"
                android:textColor="#25313F"
                android:textColorHint="#8C8C8C"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:text="Forgot Password?"
            android:textColor="#2F8A6E"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="Log In"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:backgroundTint="#157A53"
            app:cornerRadius="16dp" />

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#D9D9D9" />

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:text="or"
                android:textColor="#8E8E8E"
                android:textSize="18sp" />

            <View android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#D9D9D9" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnGoogle"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="Sign in with Google"
            android:textAllCaps="false"
            android:textColor="#2A2A2A"
            android:textSize="26sp"
            app:cornerRadius="14dp"
            app:icon="@android:drawable/presence_online"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#43C16F"
            app:strokeColor="#DADADA"
            app:strokeWidth="1dp" />

        <TextView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="No account? Register"
            android:textColor="#8E8E8E"
            android:textSize="20sp" />

    </LinearLayout>
</ScrollView>
